// pass and free
// meant to call codefree on previous code and pass control along
// args
// 0 - this code (always)
// 1 - the code buf to free
// 2 - the explicit buffer to call afterwards


LOG STRING queue.eirout CURRENTLY_RUNNING_CODE_FREE

MEMOP READ_FROMBUF V1, V0, &8
SCAFFOLD CODEFREE V1
MEMOP READ_FROMBUF V2, V0, &16
BUFREQ RELEASE V0
MEMOP MOVE V0, V2
MEMOP READ_FROMBUF V1, V0, &0
INVOKE LOCAL V1
