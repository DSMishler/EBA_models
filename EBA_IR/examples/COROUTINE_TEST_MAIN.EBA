// coroutine test main
// args
// 0 - this buf (always)


PRINT STRING "coroutine test"


SCAFFOLD CODEREAD V5 "examples/COROUTINE_2.EBA"
SCAFFOLD CODEREAD V6 "examples/COROUTINE_ADD_ONE.EBA"

BUFREQ ALLOC V1, &24
MEMOP WRITE_TOBUF V1, &0, V5

BUFREQ ALLOC V2, &16
MEMOP WRITE_TOBUF V2, &0, V6

MEMOP TRANSFER_WITH_OFFSET V1, &8, &0, &0, &8
MEMOP WRITE_TOBUF V1, &16, V2

MEMOP WRITE_TOBUF V2, &8, V1

MEMOP MOVE V0, V1
INVOKE LOCAL_BUF V0
